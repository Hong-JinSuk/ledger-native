# ─────────────────────────────────────────────────────────────────────────
#  .env.example — TEMPLATE. This file IS committed to git (placeholders only).
#  Copy it to `.env`, fill in real values. `.env` is gitignored → never committed.
# ─────────────────────────────────────────────────────────────────────────

# 🟢 PUBLIC — safe to commit here AND safe to ship inside the app.
#    ⚠️ Every EXPO_PUBLIC_* value is INLINED into the app bundle and visible to
#    anyone who inspects the app. So ONLY put public-safe values behind EXPO_PUBLIC_.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY   # anon/public key = public by design

# 🔴 SECRET — NEVER put these in this app (not here, not in any EXPO_PUBLIC_ var,
#    not in committed code). If a value must stay secret it does NOT belong in a
#    client app:
#      • Supabase service_role key   (bypasses RLS = full admin)
#      • Database password
#      • Google OAuth client secret  (lives in the Supabase dashboard, not the app)
