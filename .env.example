# Copy to `.env` and fill in from your Supabase project (Project Settings → API).
# These are PUBLIC client keys — safe to ship in the app bundle.
# EXPO_PUBLIC_ prefix is REQUIRED for the value to be exposed to the client.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
